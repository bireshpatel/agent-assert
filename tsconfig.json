{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@framework/*": ["./framework/*"],
      "@agent/*": ["./agent/*"]
    }
  },
  "include": ["agent/**/*.ts", "framework/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
