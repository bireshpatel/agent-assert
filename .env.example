# Copy this to .env and fill in the key for the provider you use.

# Anthropic (Claude) — default provider if LLM_PROVIDER is unset
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — used when LLM_PROVIDER=openai (or AgentConfig.provider: 'openai')
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: anthropic | openai | ollama (defaults to anthropic)
# LLM_PROVIDER=anthropic

# Optional: override the model id (e.g. gpt-4o-mini, claude-haiku-4-20250514, qwen3.5:latest)
# LLM_MODEL=

# Local Ollama (OpenAI-compatible API at /v1). Use LLM_PROVIDER=ollama (reads OLLAMA_BASE_URL or OPENAI_BASE_URL).
# For LLM_PROVIDER=openai, only OPENAI_BASE_URL is used as base URL — OLLAMA_BASE_URL is ignored so a stale shell var cannot point OpenAI traffic at Ollama.
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY is optional for local; defaults to a placeholder if OPENAI_BASE_URL/OLLAMA_BASE_URL is set (ollama provider only).
